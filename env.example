# Copy to .env and adjust. Used by docker compose variable substitution.

# Required for ingestion: public ATOM feed URL (or path inside the user_code container).
IMAN_ATOM_SOURCE=https://contrataciondelestado.es/sindicacion/sindicacion_643/licitacionesPerfilesContratanteCompleto3.atom

# Optional: follow rel=next until feed <updated> is before this (UTC), YYYY-MM-DD or ISO.
# IMAN_CUTOFF_DATE=2026-03-01

# Max PDF download attempts per run (0 = no limit). Same as CLI --try on download_aggregated_docs.py.
# docker-compose defaults to 5 when this is omitted; set 0 here for a full ingestion run.
IMAN_MAX_TRIES=5

# Embeddings API (OpenAI-compatible /v1/embeddings).
EMBEDDINGS_API_BASE=http://192.168.4.32:8116/v1
EMBEDDINGS_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0

# Chat / completion API (OpenAI-compatible /v1/chat/completions).
LLM_BASE_URL=http://192.168.4.32:4000/v1
LLM_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506
# Set in .env (do not commit real keys). Same key is used for both clients if the gateway expects it.
LLM_API_KEY=

# Print indented tender enrichment JSON to stdout after each LLM call (Dagster logs / pytest -s).
# IMAN_LLM_PRINT_JSON=1

# Multimodal tender analysis: rasterize PCAP.pdf only with pdftoppm (like ai-controller-example.js).
# IMAN_USE_MULTIMODAL_LLM=true
# Up to 160 PCAP pages (or fewer if the PDF is shorter); same cap on total PNGs sent to the LLM.
# IMAN_MULTIMODAL_MAX_PAGES_PER_PDF=160
# IMAN_MULTIMODAL_DPI=150
# IMAN_MULTIMODAL_MAX_IMAGES_TOTAL=160
# PNG pages per chat completion when batching multimodal calls (default 20; clamped 1–64 in code).
# IMAN_MULTIMODAL_IMAGES_PER_REQUEST=20

# Max characters of PCAP text when falling back to text-only (no images / multimodal off).
# IMAN_LLM_MAX_PDF_CHARS=120000

# Max size of merged JSON embedded in batched multimodal prompts (default 12000).
# IMAN_LLM_PARTIAL_JSON_MAX_CHARS=12000

# Vector column size must match the embedding model output (1024 for Arctic Embed L v2.0 above).
IMAN_EMBEDDING_DIMENSION=1024

# Legacy aliases (optional): OPENAI_BASE_URL, OPENAI_API_KEY, IMAN_EMBEDDING_MODEL, IMAN_CHAT_MODEL

# Set to 1 to skip optional LLM / embedding assets (faster smoke tests).
# IMAN_SKIP_LLM_ENRICHMENT=1
# IMAN_SKIP_EMBEDDINGS=1

# Cron for the Dagster schedule (default stopped until enabled in UI).
# IMAN_CRON_SCHEDULE=0 6 * * *

# Live pytest: real LLM (see tests/test_tender_llm_integration.py, tests/test_analyze_tender_one_entry_pdf.py).
# IMAN_RUN_LLM_INTEGRATION=1
# IMAN_LLM_INTEGRATION_SKIP_ON_ERROR=1

# User code gRPC is only on the Docker network (user_code:4000) unless you add a ports: mapping.
